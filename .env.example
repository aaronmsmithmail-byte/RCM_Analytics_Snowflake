# Healthcare RCM Analytics — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables are optional when running in Streamlit in Snowflake (SiS).

# ── Snowflake Connection (local development only) ────────────────────────────
# When running inside SiS, the session is provided automatically.
# These are only needed for local Streamlit development against Snowflake.

# SNOWFLAKE_ACCOUNT=xy12345.us-east-1
# SNOWFLAKE_USER=your_username
# SNOWFLAKE_PASSWORD=your_password
# SNOWFLAKE_DATABASE=RCM_ANALYTICS
# SNOWFLAKE_SCHEMA=SILVER
# SNOWFLAKE_WAREHOUSE=RCM_WH
# SNOWFLAKE_ROLE=SYSADMIN


# ── Data Directory ───────────────────────────────────────────────────────────
# Where generate_sample_data.py writes CSV files before uploading to Snowflake.

# RCM_DATA_DIR=./data/


# ── Streamlit (local development only) ───────────────────────────────────────

# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=localhost
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
